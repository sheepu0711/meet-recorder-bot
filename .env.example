# ====================================
# Meet Recorder Bot - Configuration
# ====================================

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Allowed Telegram user IDs (comma-separated)
# Only these users can control the bot
# Find your ID: send /start to @userinfobot
ALLOWED_USERS=123456789,987654321

# Guest name when joining Meet
GUEST_NAME=Recorder

# Recording settings
RECORD_FPS=30
RECORD_CRF=23
RECORD_RESOLUTION=1280x720
MAX_DURATION=10800

# Auto-stop when participant count drops below this number (0 = disabled)
MIN_PARTICIPANTS=10

# Virtual display
DISPLAY_NUM=99

# Chrome debug port
CDP_PORT=9222

# Paths (change if needed)
RECORDINGS_DIR=./recordings

# Download link server
# SERVER_HOST: your VPS public IP (auto-detected via ifconfig.me if left blank)
SERVER_HOST=
DOWNLOAD_PORT=8080
